# Streamura Backend Environment Configuration
# Copy this file to .env and configure for your environment

# Application Settings
ENV=development
HOST=0.0.0.0
PORT=8001
DEBUG=True

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=streamura
DB_USER=streamura
DB_PASSWORD=streamura_dev
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600

# Authentication
JWT_SECRET=streamura_super_secure_jwt_secret_key_2026_production_ready
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# Streaming Configuration
STREAM_TIMEOUT=3600
MAX_STREAM_DURATION=7200
STREAM_QUALITY_LEVELS=low,medium,high

# Stripe Configuration (Sandbox/Test Mode)
# These are Stripe's public test keys - safe for demos
STRIPE_SECRET_KEY=sk_test_4eC39HqLyjWDarjtT1zdp7dc
STRIPE_PUBLISHABLE_KEY=pk_test_TYooMQauvdEDq54NiTphI7jx
STRIPE_WEBHOOK_SECRET=whsec_test_secret
PAYOUT_THRESHOLD=1.00
REVENUE_SPLIT=0.9
PLATFORM_FEE=0.1

# VAPID Keys for Push Notifications (G3 - Gap fix)
VAPID_PUBLIC_KEY=BEl62iUYgUivxIkv69yViEuiBIa-Ib9-SkvMeAtA3LFgDzkrxZJjSgSnfckjBCuErN2nD8j3IqvDJMxqw1B0hMw
VAPID_PRIVATE_KEY=demo_private_key_replace_in_production
